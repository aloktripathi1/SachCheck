ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
ANTHROPIC_EXTRACT_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SYNTHESIS_MODEL=claude-sonnet-4-6
GOOGLE_FC_API_KEY=YOUR_GOOGLE_FC_KEY_HERE
CLAIMBUSTER_API_KEY=
FRONTEND_ORIGIN=http://localhost:5173

# Web Search Fallback — both free, no credit card required
# Fires automatically when Tier-1 evidence (Google FC, Wikipedia, GDELT) is insufficient.
GOOGLE_CSE_API_KEY=   # Free. Same Google Cloud account as GOOGLE_FC_API_KEY.
                      # Enable "Custom Search JSON API" at console.cloud.google.com
                      # 100 free queries/day; 10,000/day with billing enabled (still free tier).
GOOGLE_CSE_ID=        # Free. Create at programmablesearchengine.google.com
                      # Set "Search the entire web" to ON in engine settings.
# DuckDuckGo needs no key or config — always active as secondary fallback.
